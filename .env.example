# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic API Key — get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL connection string
# Local dev: postgresql+asyncpg://keyscan:keyscan_dev@localhost:5432/keyscan
# Railway:   provided by Railway dashboard → your project → Variables
DATABASE_URL=postgresql+asyncpg://keyscan:keyscan_dev@localhost:5432/keyscan

# Redis URL (local dev default works with docker-compose)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL credentials (used by docker-compose postgres service)
POSTGRES_USER=keyscan
POSTGRES_PASSWORD=keyscan_dev
POSTGRES_DB=keyscan

# Admin credentials for the review queue (change before deploying)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
